{
  "name": "ztui",
  "version": "0.1.0",
  "description": "Textual-like TUI framework for TypeScript and Bun with React JSX support",
  "type": "module",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run examples/demo.tsx",
    "demo": "bun run examples/demo.tsx",
    "demo:protocols": "bun run examples/advanced_protocols.tsx",
    "demo:heroicons": "bun run examples/heroicons_demo.tsx",
    "demo:image": "bun run examples/image_demo.tsx",
    "demo:rich": "bun run examples/rich_demo.tsx",
    "demo:genui": "bun run examples/generative_ui.tsx",
    "demo:themes": "bun run examples/theme_explorer.tsx",
    "demo:text": "bun run examples/textarea_demo.tsx",
    "demo:clipboard": "bun run examples/clipboard_demo.tsx",
    "demo:tabs": "bun run examples/tabcontainer_demo.tsx",
    "demo:fileicon": "bun run examples/fileicon_demo.tsx",
    "demo:table": "bun run examples/table_demo.tsx",
    "demo:tree": "bun run examples/tree_demo.tsx",
    "demo:form": "bun run examples/form_validation_demo.tsx",
    "demo:waiting": "bun run examples/waiting_demo.tsx",
    "demo:status": "bun run examples/status_demo.tsx",
    "demo:overlay": "bun run examples/overlay_demo.tsx",
    "demo:qa": "bun run examples/questionanswer_demo.tsx",
    "demo:hotkeys": "bun run examples/hotkeys_demo.tsx",
    "demo:list": "bun run examples/listview_demo.tsx",
    "demo:richlog": "bun run examples/richlog_demo.tsx",
    "demo:mdstream": "bun run examples/markdown_stream_demo.tsx",
    "demo:collapsible": "bun run examples/collapsible_demo.tsx",
    "demo:diff": "bun run examples/diff_demo.tsx",
    "demo:sparkline": "bun run examples/sparkline_demo.tsx",
    "demo:web": "bun run examples/web_demo.tsx",
    "web:debug": "bun run scripts/web-debug.ts",
    "test": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.config.e2e.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "postinstall": "git config core.hooksPath .githooks || true",
    "review": "bun run scripts/code-review.ts"
  },
  "dependencies": {
    "beautiful-mermaid": "^1.1.3",
    "heroicons": "^2.2.0",
    "jpeg-js": "^0.4.4",
    "marked": "^17.0.1",
    "omggif": "^1.0.10",
    "opentype.js": "^2.0.0",
    "pngjs": "^7.0.0",
    "prismjs": "1.30.0",
    "react": "19.2.6",
    "react-reconciler": "0.33.0",
    "remend": "^1.3.0",
    "sharp": "^0.34.5",
    "string-width": "^8.2.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/bun": "latest",
    "@types/node": "25.9.0",
    "@types/opentype.js": "^1.3.10",
    "@types/pngjs": "^6.0.5",
    "@types/prismjs": "1.26.6",
    "@types/react": "19.2.15",
    "@types/react-reconciler": "0.33.0",
    "@vitest/coverage-v8": "4.1.7",
    "@xterm/headless": "^6.0.0",
    "playwright": "^1.60.0",
    "vitest": "4.1.7"
  }
}
