{
  "name": "ztui",
  "version": "0.2.0",
  "description": "Textual-like TUI framework for TypeScript and Bun with React JSX support",
  "type": "module",
  "main": "src/core.ts",
  "module": "src/core.ts",
  "exports": {
    ".": "./src/core.ts",
    "./react": "./src/react.ts",
    "./markdown": "./src/markdown.ts",
    "./syntax": "./src/syntax.ts",
    "./mermaid": "./src/mermaid.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "bun run examples/gallery/run.tsx",
    "demo": "bun run examples/gallery/run.tsx",
    "demo:web": "bun run examples/gallery/run.tsx --web",
    "demo:list": "bun run examples/gallery/run.tsx --list",
    "web:debug": "bun run scripts/web-debug.ts",
    "test": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.config.e2e.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "postinstall": "git config core.hooksPath .githooks || true",
    "review": "bun run scripts/code-review.ts"
  },
  "dependencies": {
    "heroicons": "^2.2.0",
    "jpeg-js": "^0.4.4",
    "omggif": "^1.0.10",
    "pngjs": "^7.0.0",
    "remend": "^1.3.0",
    "string-width": "^8.2.1"
  },
  "peerDependencies": {
    "beautiful-mermaid": "^1.1.3",
    "marked": "^17.0.1",
    "opentype.js": "^2.0.0",
    "prismjs": "^1.30.0",
    "react": "^19.0.0",
    "react-reconciler": "^0.33.0",
    "sharp": "^0.34.0"
  },
  "peerDependenciesMeta": {
    "beautiful-mermaid": {
      "optional": true
    },
    "marked": {
      "optional": true
    },
    "opentype.js": {
      "optional": true
    },
    "prismjs": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-reconciler": {
      "optional": true
    },
    "sharp": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/bun": "latest",
    "@types/node": "25.9.0",
    "@types/opentype.js": "^1.3.10",
    "@types/pngjs": "^6.0.5",
    "@types/prismjs": "1.26.6",
    "@types/react": "19.2.15",
    "@types/react-reconciler": "0.33.0",
    "@vitest/coverage-v8": "4.1.7",
    "@xterm/headless": "^6.0.0",
    "beautiful-mermaid": "^1.1.3",
    "marked": "^17.0.1",
    "opentype.js": "^2.0.0",
    "playwright": "^1.60.0",
    "prismjs": "1.30.0",
    "react": "19.2.6",
    "react-reconciler": "0.33.0",
    "sharp": "^0.34.5",
    "vitest": "4.1.7"
  }
}
