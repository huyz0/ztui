{
  "name": "ztui",
  "version": "0.1.0",
  "description": "Textual-like TUI framework for TypeScript and Bun with React JSX support",
  "type": "module",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run examples/demo.tsx",
    "demo:protocols": "bun run examples/advanced_protocols.tsx",
    "demo:heroicons": "bun run examples/heroicons_demo.tsx",
    "demo:image": "bun run examples/image_demo.tsx",
    "test": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "postinstall": "git config core.hooksPath .githooks || true",
    "review": "bun run scripts/code-review.ts"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "heroicons": "^2.2.0",
    "jpeg-js": "^0.4.4",
    "markdown-it": "14.1.1",
    "omggif": "^1.0.10",
    "picocolors": "^1.1.1",
    "pngjs": "^7.0.0",
    "prismjs": "1.30.0",
    "react": "19.2.6",
    "react-reconciler": "0.33.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/bun": "latest",
    "@types/markdown-it": "14.1.2",
    "@types/node": "25.9.0",
    "@types/pngjs": "^6.0.5",
    "@types/prismjs": "1.26.6",
    "@types/react": "19.2.15",
    "@types/react-reconciler": "0.33.0",
    "@vitest/coverage-v8": "4.1.7",
    "@xterm/headless": "^6.0.0",
    "vitest": "4.1.7"
  }
}
