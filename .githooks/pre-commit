#!/bin/sh
echo "=== Running Pre-Commit Validation ==="

echo "1. Checking code formatting and style (Biome)..."
bun run lint
if [ $? -ne 0 ]; then
  echo "❌ Formatting checks failed! Please run 'bun run lint:fix' or edit the code to comply."
  exit 1
fi

echo "2. Type-checking (tsc)..."
bun run typecheck
if [ $? -ne 0 ]; then
  echo "❌ Type errors found! Run 'bun run typecheck' to see details."
  exit 1
fi

echo "3. Building (JS + d.ts)..."
bun run build
if [ $? -ne 0 ]; then
  echo "❌ Build failed! 'tsc -p tsconfig.build.json' caught an error tsc --noEmit doesn't (e.g. rootDir / d.ts emit)."
  exit 1
fi

echo "4. Running unit and integration tests (Vitest)..."
bun run test
if [ $? -ne 0 ]; then
  echo "❌ Unit tests failed or coverage threshold was not met!"
  exit 1
fi

echo "5. Running end-to-end tests (real binary)..."
bun run test:e2e
if [ $? -ne 0 ]; then
  echo "❌ E2E tests failed!"
  exit 1
fi

echo "6. Checking for circular dependencies (madge)..."
bunx madge --circular --extensions ts,tsx src
if [ $? -ne 0 ]; then
  echo "❌ Circular dependency detected! Keep the import graph acyclic."
  exit 1
fi

echo "7. Layer-leak guard (no driver/ANSI in widgets/core)..."
bun run review
if [ $? -ne 0 ]; then
  echo "❌ Layer-leak guard failed! Move terminal/protocol specifics into a Driver method."
  exit 1
fi

echo "✅ Pre-commit checks passed successfully."
exit 0
